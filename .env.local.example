# ----------------------------------------------------------------------------
# AutoGuardian / AI DriveX — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# `.env.local` is git-ignored automatically by Next.js.
# ----------------------------------------------------------------------------

# --- Anthropic (Claude) -------------------------------------------------------
# Used by route handlers via @ai-sdk/anthropic. SERVER-SIDE ONLY — never
# prefix with NEXT_PUBLIC_ and never reference it from a client component.
ANTHROPIC_API_KEY=sk-ant-...

# Optional override; defaults to the latest Claude model the SDK ships with.
# Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6


# --- Supabase Cloud Sync (Phase 5) -------------------------------------------
# Both keys are required to enable sync. Without them the app runs fully
# offline and the indicator shows "Supabase not configured".
# anon key is safe to expose in the browser — never use service_role here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
