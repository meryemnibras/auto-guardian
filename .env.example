# Copy this file to .env.local and fill in any of the keys below.
# All keys are SERVER-SIDE — never prefix with NEXT_PUBLIC_.
# App works fully without any keys (mock fallbacks everywhere).

# --- Groq (FREE — no credit card, works in most regions) --------------------
# Recommended free provider. Get a key in seconds: https://console.groq.com/keys
# OpenAI-compatible, very fast. Used automatically when set (preferred over
# Gemini in the chat fallback chain).
GROQ_API_KEY=
# Optional override; defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (FREE tier) ----------------------------------------------
# Get a free key (no credit card): https://aistudio.google.com/apikey
# Note: new projects in some regions are denied generateContent access.
# If Gemini returns 403 "denied access", use GROQ_API_KEY above instead.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override; defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic (Claude) — paid -----------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (GPT) — paid -----------------------------------------------------
# Not wired into any route yet, but the SDK is ready in providers.ts
OPENAI_API_KEY=

# --- Supabase (accounts + permanent cloud storage) --------------------------
# FREE tier. Enables user sign-up/login and long-term sync of expenses,
# diagnostics, fuel and maintenance records across devices.
# Create a project at https://supabase.com, then run supabase/schema.sql in
# the SQL editor, and copy these from: Settings → API.
# These two are CLIENT-SIDE (NEXT_PUBLIC_) on purpose — the anon key is safe
# to expose because Row Level Security protects every row.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key — bypasses RLS for /api/checkout & /api/waitlist.
# NEVER prefix with NEXT_PUBLIC_. Copy from Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (payments / subscriptions) --------------------------------------
# Powers /checkout. Start in TEST mode (toggle top-right of the Stripe
# dashboard) — test cards never move real money. Switch to live keys only
# after a full test run.
#   1) Secret key:  Developers → API keys → "Secret key" (sk_test_... / sk_live_...)
#   2) Webhook:     Developers → Webhooks → Add endpoint
#                   URL:    https://<your-domain>/api/webhooks/stripe
#                   Events: checkout.session.completed,
#                           customer.subscription.deleted,
#                           invoice.payment_failed
#                   Then "Reveal signing secret" → whsec_...
# Plan prices live in code (lib/currency.ts) — no Stripe product needed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (receipt + founder-notification emails) — optional --------------
# Free at https://resend.com. Without it, payments still work but no receipt
# email is sent. RESEND_FROM_EMAIL must be a verified domain (or use the
# default onboarding@resend.dev for testing). NOTIFY_EMAIL gets a ping on
# every new paid subscription.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFY_EMAIL=

# --- App URL (used for Stripe redirect URLs) --------------------------------
# Set to your public domain so Checkout returns to the right place.
NEXT_PUBLIC_APP_URL=
