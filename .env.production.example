# ============================================================================
# AI DriveX — production environment variables
# ----------------------------------------------------------------------------
# Copy this to `.env.production` on the VPS and fill in the real values:
#     cp .env.production.example .env.production
#     nano .env.production
#
# NEVER commit .env.production to git — it holds secret keys.
# ============================================================================

# ---- Public (safe to expose; inlined into the browser bundle) --------------
NEXT_PUBLIC_APP_URL=https://aidrivex.agency
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
NEXT_PUBLIC_WHATSAPP_NUMBER=9665XXXXXXXX
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/demo

# ---- Supabase (server-only) ------------------------------------------------
# Settings → API → service_role secret. Bypasses RLS — keep private.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ---- AI provider (pick at least one) --------------------------------------
# Gemini is free for new accounts: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional alternatives:
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ---- Stripe (payments) -----------------------------------------------------
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → your endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Resend (transactional email) ------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AI DriveX <hi@aidrivex.agency>
# Where founder notifications (new signup / new sale) are sent:
NOTIFY_EMAIL=ubcdsg@gmail.com

# ---- Android TWA (optional, for Play Store asset-links) --------------------
TWA_SHA256_FINGERPRINT=
TWA_PACKAGE_NAME=ai.drivex.app
